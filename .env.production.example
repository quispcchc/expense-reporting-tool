# ===========================================
# Production Environment Configuration
# ===========================================
# Copy this file to .env and fill in the values
# Used by: docker-compose.prod.yml

# -------------------------------------------
# Application
# -------------------------------------------
APP_NAME="Volunteering Expense Tool"
APP_ENV=production
APP_KEY= # Generate with: php artisan key:generate --show
APP_DEBUG=false
APP_URL=https://your-domain.com

# Frontend URLs for CORS and Sanctum
FRONTEND_URL=https://your-domain.com
SANCTUM_STATEFUL_DOMAINS=your-domain.com
SESSION_DOMAIN=.your-domain.com

# -------------------------------------------
# Database (PostgreSQL through PgBouncer)
# -------------------------------------------
# These are used by the PostgreSQL container
POSTGRES_DB=expense_db
POSTGRES_USER=expense_user
POSTGRES_PASSWORD= # MUST BE STRONG

# -------------------------------------------
# PgBouncer Settings
# -------------------------------------------
PGBOUNCER_POOL_MODE=transaction
PGBOUNCER_MAX_CLIENT_CONN=1000
PGBOUNCER_DEFAULT_POOL_SIZE=20

# -------------------------------------------
# Redis (Optional, but recommended for production)
# -------------------------------------------
# REDIS_HOST=redis
# REDIS_PASSWORD=null
# REDIS_PORT=6379

# -------------------------------------------
# Laravel Drivers
# -------------------------------------------
CACHE_DRIVER=database
QUEUE_CONNECTION=database
SESSION_DRIVER=database
SESSION_LIFETIME=120

# -------------------------------------------
# Mail (SMTP)
# -------------------------------------------
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# -------------------------------------------
# Build-time Variables (Frontend)
# -------------------------------------------
# Used by Docker to build the React app
VITE_API_BASE_URL=https://your-domain.com/api
